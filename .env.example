# Runtime
NODE_ENV=development
PORT=5000

# Auth
# Minimum 32 characters required
JWT_SECRET=replace_with_a_secure_32_plus_char_secret

# Database (MySQL)
# Either DATABASE_URL or MYSQL_URL can be used
DATABASE_URL=mysql://user:password@127.0.0.1:3306/asset_linker
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/asset_linker

# Ganache / blockchain
GANACHE_RPC_URL=http://127.0.0.1:8545
DEPLOYER_PRIVATE_KEY=replace_with_ganache_private_key

# Optional contract addresses (after deploy)
USER_REGISTRY_ADDRESS=
MEDICINE_TRACKING_ADDRESS=
CHAIN_ID=1337
